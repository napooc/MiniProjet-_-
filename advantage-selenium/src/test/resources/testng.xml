<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Authentication Suite" verbose="1">
    <test name="Authentication Tests" preserve-order="true">
        <classes>
            <!-- 1. SignUp en premier pour créer le compte -->
            <class name="tests.authentication.SignUpTest"/>
            <!-- 2. SignIn ensuite avec le même compte -->
            <class name="tests.authentication.SignInTest"/>
        </classes>
    </test>
</suite>
